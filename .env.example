# Copie este arquivo para ".env" na mesma pasta e preencha com seus valores.
# PowerShell: Copy-Item .env.example .env

# Sessão (qualquer string longa em dev)
SECRET_KEY=troque-por-uma-string-secreta-em-producao

# PostgreSQL (Sequelize — receitas, usuários, categorias, etc.)
DB_HOST=127.0.0.1
DB_NAME=receitas
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# MongoDB (Mongoose — comentários)
# Local: mongodb://127.0.0.1:27017/receitas
# Atlas: mongodb+srv://USUARIO:SENHA@cluster.xxxxx.mongodb.net/receitas?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/receitas
