<div class="card stack">
    <h1 class="page-title">Novo comentário</h1>
    <p class="page-lead">Registre um comentário com título, texto e autor.</p>

    <form action="/comentarioCreate" method="post" class="stack">
        <div class="form-row">
            <label for="titulo">Título</label>
            <input type="text" name="titulo" id="titulo" required>
        </div>
        <div class="form-row">
            <label for="texto">Texto</label>
            <textarea name="texto" id="texto" required></textarea>
        </div>
        <div class="form-row">
            <label for="autor">Autor</label>
            <input type="text" name="autor" id="autor" required>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Cadastrar</button>
            <a class="btn btn-ghost" href="/comentarioList">Cancelar</a>
        </div>
    </form>
</div>
