<div class="card stack">
    <h1 class="page-title">Nova habilidade</h1>
    <p class="page-lead">Cadastre uma habilidade que os usuários poderão declarar (ex.: fermentação, confeitaria).</p>

    <form action="/habilidadeCreate" method="post" class="stack">
        <div class="form-row">
            <label for="nome">Nome da habilidade</label>
            <input type="text" name="nome" id="nome" required>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Cadastrar</button>
            <a class="btn btn-ghost" href="/habilidadeList">Cancelar</a>
        </div>
    </form>
</div>
