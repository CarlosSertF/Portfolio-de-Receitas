<!DOCTYPE html>
<html>
    <head>
        <title>Sistema de Controle de Receitas</title>
    </head>
    <body>
        <center>
            <h1>Sistema de Controle de Receitas</h1>
            {{#if isAdmin}}
                <a href = "/usuarioCreate">
                    <button>Cadastrar Usuário</button>
                </a>
                <a href = "/usuarioList">
                    <button>Listar Usuários</button>
                </a>
            {{/if}}
            <a href="/categoriaCreate">
                <button>Cadastrar Categoria</button>
            </a>
            <a href="/categoriaList">
                <button>Listar Categorias</button>
            </a>
            <a href="/receitaCreate">
                <button>Cadastrar Receita</button>
            </a>
            <a href="/receitaList">
                <button>Listar Receitas</button>
            </a>
            {{#if isAdmin}}
            <a href="/habilidadeCreate">
                <button>Cadastrar Habilidade</button>
            </a>
            <a href="/habilidadeList">
                <button>Listar Habilidades</button>
            </a>
            {{/if}}
            {{#unless isAdmin}}
            <a href="/usuarioHabilidadeList">
                <button>Minhas Habilidades</button>
            </a>
            <a href="/usuarioHabilidadeCreate">
                <button>Adicionar Habilidade</button>
            </a>
            {{/unless}}
            <br> <br>
            <a href="/comentarioCreate">
                <button>Cadastrar Comentário</button>
            </a>
            <a href="/comentarioList">
                <button>Listar Comentários</button>
            </a>
            <a href ="/logout">
                <button>Logout</button>
            </a>
            <br> <br>
            {{{body}}}                                    
        </center>
    </body>
</html>