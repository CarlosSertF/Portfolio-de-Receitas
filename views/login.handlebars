<div class="login-page">
    <div class="login-grid">
        <section class="login-hero" aria-labelledby="login-hero-title">
            <h2 id="login-hero-title">Organize receitas, categorias e habilidades</h2>
            <p>Área restrita para a equipe. Visitantes podem explorar o acervo público sem conta.</p>
        </section>

        <div class="login-card stack">
            <div>
                <h1 class="page-title" style="margin-bottom:0.25rem;">Entrar</h1>
                <p class="page-lead" style="margin:0;">Use seu login e senha para acessar o painel.</p>
            </div>

            <form action="/login" method="post" class="stack">
                <div class="form-row">
                    <label for="login">Login</label>
                    <input type="text" name="login" id="login" autocomplete="username" required>
                </div>
                <div class="form-row">
                    <label for="senha">Senha</label>
                    <input type="password" name="senha" id="senha" autocomplete="current-password" required>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Entrar</button>
                </div>
            </form>

            <hr style="border:none;border-top:1px solid var(--line);margin:0.25rem 0;">

            <div>
                <h2 class="page-title" style="font-size:1.1rem;margin-bottom:0.35rem;">Visitante</h2>
                <p class="page-lead" style="margin-bottom:0.75rem;">Explore sem fazer login:</p>
                <div class="form-actions">
                    <a class="btn btn-secondary" href="/public/receitas">Receitas</a>
                    <a class="btn btn-secondary" href="/public/categorias">Categorias</a>
                    <a class="btn btn-ghost" href="/public/relatorio-habilidades">Relatório</a>
                </div>
            </div>
        </div>
    </div>
</div>
