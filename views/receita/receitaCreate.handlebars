<form action="/receitaCreate" method="post">
    Nome: <input type="text" name="nome">
    <br><br>
    Ingredientes: <input type="text" name="ingredientes">
    <br><br>
    Preparo: <input type="text" name="preparo">
    <br><br>
    Categoria:
    <select name="categoriaNome">
        {{#each categorias}}
        <tr>
            <option value={{nome}}>{{nome}}</option>
        </tr>
        {{/each}}
    </select>
    <br> <br>
    <input type="submit" value="Cadastrar">
</form>