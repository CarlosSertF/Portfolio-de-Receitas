<table border="1px">
    <tr>
        <td>Nome</td>
        <td>Preparo</td>
        <td>Ingredientes</td>
        <td>Categoria</td>
        <td>Editar</td>
        <td>Deletar</td>
    </tr>
    {{#each receitas}}
    <tr>
        <td>{{nome}}</td>
        <td>{{preparo}}</td>
        <td>{{ingredientes}}</td>
        <td>{{categoriaNome}}</td>
        <td><a href="receitaUpdate/{{nome}}">Editar</a></td>
        <td><a href="receitaDelete/{{nome}}">Deletar</a></td>
    </tr>
    {{/each}}
</table>