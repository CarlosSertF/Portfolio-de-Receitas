<div class="card stack">
    <h1 class="page-title">Editar usuário</h1>
    <p class="page-lead">Atualize login, nome ou senha. Evite reutilizar senhas fracas em produção.</p>

    <form action="/usuarioUpdate" method="post" class="stack">
        <input type="hidden" name="id" value="{{usuario.id}}">
        <div class="form-row">
            <label for="login">Login</label>
            <input type="text" name="login" id="login" value="{{usuario.login}}" required>
        </div>
        <div class="form-row">
            <label for="nome">Nome</label>
            <input type="text" name="nome" id="nome" value="{{usuario.nome}}" required>
        </div>
        <div class="form-row">
            <label for="senha">Senha</label>
            <input type="password" name="senha" id="senha" value="{{usuario.senha}}" autocomplete="new-password" required>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Salvar</button>
            <a class="btn btn-ghost" href="/usuarioList">Voltar</a>
        </div>
    </form>
</div>
